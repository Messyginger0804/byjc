#!/bin/sh
echo "Running lint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "Lint failed. Fix errors before pushing."
  exit 1
fi

echo "Running tests..."
npm run test:run
if [ $? -ne 0 ]; then
  echo "Tests failed. Fix failures before pushing."
  exit 1
fi

echo "Running build..."
npm run build
if [ $? -ne 0 ]; then
  echo "Build failed. Fix errors before pushing."
  exit 1
fi
